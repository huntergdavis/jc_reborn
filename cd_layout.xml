<?xml version="1.0" encoding="UTF-8"?>
<!-- Johnny Reborn PS1 CD-ROM Layout -->
<iso_project image_name="jcreborn.bin" cue_sheet="jcreborn.cue">

    <!-- Main data track -->
    <track type="data">
        <identifiers
            system="PLAYSTATION"
            application="JOHNNY_REBORN"
            volume="JOHNNY_REBORN"
            publisher="OPEN_SOURCE"
            preparer="PSN00BSDK"
        />

        <!-- Directory tree on CD -->
        <directory_tree>
            <!-- PS1 executable - paths relative to cd_layout.xml location -->
            <file name="JCREBORN.EXE" type="data" source="build-ps1/jcreborn.exe"/>

            <!-- Original Sierra resource files -->
            <file name="RESOURCE.MAP" type="data" source="jc_resources/RESOURCE.MAP"/>
            <file name="RESOURCE.001" type="data" source="jc_resources/RESOURCE.001"/>

            <!-- Sound files (if available) -->
            <!-- Note: These need to be converted to PS1 VAG format or streamed as XA audio -->
            <!-- For now, we'll omit them and implement SPU playback later -->
            <!--
            <file name="SOUND0.VAG" type="data" source="sounds/sound0.vag"/>
            <file name="SOUND1.VAG" type="data" source="sounds/sound1.vag"/>
            ... etc ...
            -->
        </directory_tree>
    </track>

    <!-- Optional: CDDA audio tracks could be added here for music -->
    <!-- <track type="audio" source="music/track01.wav"/> -->

</iso_project>
